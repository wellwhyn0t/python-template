# ============================================
# 1. Python артефакты (не нужны в образе)
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================
# 2. Виртуальное окружение (ОЧЕНЬ ВАЖНО!)
# ============================================
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# ============================================
# 3. Секреты и конфиги локальной среды
# ============================================
.env
.env.*
!.env.example          # example оставляем как документацию
!.env.template
*.pem
*.key
*.crt
secrets/
credentials/

# ============================================
# 4. IDE и редакторы
# ============================================
.vscode/
.idea/
.gigacode_vsc/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# ============================================
# 5. Git и CI/CD
# ============================================
.git/
.gitignore
.github/
.gitattributes
.gitmodules
*.md
!README.md            # если нужен в образе (редко)
CHANGELOG.md
LICENSE

# ============================================
# 6. Docker файлы (не нужны внутри образа)
# ============================================
docker-compose*.yml
docker-compose*.yaml
Dockerfile*
.dockerignore

# ============================================
# 7. Тесты и локальные данные (не нужны в production)
# ============================================
tests/
test/
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# Локальные БД и дампы
*.sqlite3
*.db
*.dump
*.sql

# ============================================
# 8. Локальные media/static (собираются внутри контейнера)
# ============================================
media/                  # пользовательские загрузки — монтируются volume'ом
staticfiles/            # collectstatic запускается при старте
static/                 # если собирается внутри контейнера

# ============================================
# 9. Node.js (если используешь фронтенд в том же репо)
# ============================================
node_modules/
npm-debug.log
yarn-error.log
.pnpm-debug.log
.next/
out/
dist/
coverage/

# ============================================
# 10. Логи и временные файлы
# ============================================
*.log
logs/
tmp/
temp/
*.tmp